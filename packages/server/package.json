{
  "name": "server",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "auth:schema": "bun run --bun auth generate --output db/schema/auth.ts -y && bun prettier -w db/schema/auth.ts",
    "db:push": "bun run drizzle-kit push"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@googleapis/gmail": "^16.1.1",
    "better-auth": "^1.5.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "auth": "^1.5.4",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9"
  }
}
